{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "warpApp/backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/search", "destination": "/warpApp/backend/main.py" },
    { "source": "/update_data", "destination": "/warpApp/backend/main.py" },
    { "source": "/delete_data", "destination": "/warpApp/backend/main.py" },
    { "source": "/get_image", "destination": "/warpApp/backend/main.py" },
    { "source": "/upload_image", "destination": "/warpApp/backend/main.py" }
  ]
}
