{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } },
    { "src": "main.py", "use": "@vercel/python" }
  ],
  "rewrites": [
    { "source": "/search", "destination": "/main.py" },
    { "source": "/update_data", "destination": "/main.py" },
    { "source": "/delete_data", "destination": "/main.py" },
    { "source": "/get_image", "destination": "/main.py" }
  ]
}
